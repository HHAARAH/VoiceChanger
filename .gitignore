# ====================================
# STM32CubeIDE 项目专用 .gitignore
# ====================================

# 编译输出文件夹
Debug/
Release/

# 编译生成的中间文件
*.o
*.d
*.lst
*.map
*.hex
*.bin
*.elf
*.axf

# CubeIDE 个人配置文件夹（不同电脑配置不同）
.settings/

# CubeIDE 启动配置（包含调试器序列号等个人信息）
*.launch

# 其他编译残留
*.crf
*.lnp
*.dep
*.bak
*.swp
*.swo
*~